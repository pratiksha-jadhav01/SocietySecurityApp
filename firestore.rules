rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isAuth() {
      return request.auth != null;
    }

    // Helper: get the role of the current user safely from 'users' collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'none');
    }

    // Helper: is current user admin? (Checks for lowercase 'admin')
    function isAdmin() {
      return isAuth() && getUserRole() == "admin";
    }

    // Helper: is current user owner?
    function isOwner() {
      return isAuth() && getUserRole() == "owner";
    }

    // --- COLLECTION RULES ---

    // USERS collection
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && (request.auth.uid == userId || isAdmin());
    }

    // COMPLAINTS collection
    match /complaints/{complaintId} {
      allow read: if isAuth();
      allow create: if isAuth();
      // Update: Admin can update status/response. Owner can update their own complaint.
      allow update: if isAuth() && (
        isAdmin() ||
        resource.data.get('ownerUid', '') == request.auth.uid ||
        resource.data.get('userId', '') == request.auth.uid
      );
      // Delete: Admin or Creator
      allow delete: if isAuth() && (
        isAdmin() ||
        resource.data.get('ownerUid', '') == request.auth.uid ||
        resource.data.get('userId', '') == request.auth.uid
      );
    }

    // NOTICES collection
    match /notices/{noticeId} {
      allow read: if isAuth();
      // FIX: Standardized admin check for posting notices (allows create, update, delete)
      allow write: if isAdmin();
    }

    // MAINTENANCE collection
    match /maintenance/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // BILLS collection
    match /bills/{billId} {
      allow read: if isAuth();
      // Admin can manage all. Owner can update their own (status to Paid).
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isOwner() && (
        resource.data.get('flatNo', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('flatNumber', '') ||
        resource.data.get('flatNo', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('flatNo', '')
      ));
    }

    // VISITORS collection
    match /visitors/{visitorId} {
      allow read, create: if isAuth();
      // Owners can update (approve/reject) visitors destined for their own flat.
      allow update: if isAuth() && (
        isAdmin() ||
        getUserRole() == "guard" ||
        (isOwner() && (
          resource.data.get('flatNumber', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('flatNumber', '') ||
          resource.data.get('flatNumber', '') == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('flatNo', '')
        ))
      );
      allow delete: if isAuth() && (
        isAdmin() ||
        getUserRole() == "guard"
      );
    }

    // DAILY HELPERS collection
    match /dailyHelpers/{helperId} {
      allow read: if isAuth();
      allow create: if isOwner() || isAdmin();
      allow update, delete: if isAdmin() || (isOwner() && resource.data.get('ownerUid', '') == request.auth.uid);
    }

    // NOTIFICATIONS collection
    match /notifications/{notifId} {
      allow create, read, update: if isAuth();
      allow delete: if isAdmin() || resource.data.get('targetUid', '') == request.auth.uid;
    }
  }
}