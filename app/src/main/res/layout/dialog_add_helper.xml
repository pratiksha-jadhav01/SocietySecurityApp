<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/body_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Helper Name"
            app:boxStrokeColor="@color/cream_field_stroke"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHelperName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/dark_brown" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Phone Number"
            app:boxStrokeColor="@color/cream_field_stroke"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHelperPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:maxLength="10"
                android:textColor="@color/dark_brown" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Helper Type"
            android:textColor="@color/soft_brown"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <Spinner
            android:id="@+id/spinnerType"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_search_cream" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Expected Arrival Time (e.g. 08:00 AM)"
            app:boxStrokeColor="@color/cream_field_stroke"
            app:hintTextColor="@color/primary">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etHelperTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="time"
                android:textColor="@color/dark_brown" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Working Schedule"
            android:textColor="@color/dark_brown"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <CheckBox
            android:id="@+id/cbDaily"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Every Day (Daily)"
            android:textColor="@color/dark_brown"
            app:buttonTint="@color/primary" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2">
            <CheckBox android:id="@+id/cbMon" android:text="Monday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbTue" android:text="Tuesday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbWed" android:text="Wednesday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbThu" android:text="Thursday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbFri" android:text="Friday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbSat" android:text="Saturday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
            <CheckBox android:id="@+id/cbSun" android:text="Sunday" android:layout_width="0dp" android:layout_columnWeight="1" android:textColor="@color/dark_brown" app:buttonTint="@color/primary"/>
        </GridLayout>

    </LinearLayout>
</ScrollView>