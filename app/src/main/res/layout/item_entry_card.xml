<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardEntry"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/card_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/ivEntryType"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="@color/soft_brown" />

            <TextView
                android:id="@+id/tvEntryTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="10:30 AM"
                android:textColor="@color/soft_brown"
                android:textSize="10sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvEntryName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="John Doe"
            android:textColor="@color/dark_brown"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvEntryStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Visitor • Flat 402"
            android:textColor="@color/soft_brown"
            android:textSize="11sp" />

        <ProgressBar
            android:id="@+id/pbEntryStatus"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:layout_marginTop="16dp"
            android:progress="100"
            android:progressTint="#2E7D32" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>