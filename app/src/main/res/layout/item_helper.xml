<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardBackgroundColor="#FFF9F2"
    app:strokeColor="#E8D5BC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivHelperAvatar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@android:drawable/ic_menu_myplaces"
                app:civ_border_color="#E0C9A6"
                app:civ_border_width="2dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvHelperName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Helper Name"
                    android:textColor="#6B4C2A"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvHelperType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Maid"
                    android:textColor="#A07850"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true"
                app:thumbTint="#A07850"
                app:trackTint="#C8A882" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSchedule"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Mon, Wed, Fri"
            android:textColor="#A07850"
            android:textSize="13sp"
            app:drawableStartCompat="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="8dp"
            app:drawableTint="#A07850" />

        <TextView
            android:id="@+id/tvEntryTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Expected: 08:00 AM"
            android:textColor="#A07850"
            android:textSize="13sp"
            app:drawableStartCompat="@android:drawable/ic_menu_recent_history"
            android:drawablePadding="8dp"
            app:drawableTint="#A07850" />

        <!-- Last Seen Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#A07850" />
            <TextView
                android:id="@+id/tvLastSeen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Last seen: Never recorded"
                android:textColor="#A07850"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E8D5BC" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.2"
                android:text="History"
                android:textColor="#A07850"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_recent_history"
                app:iconSize="16dp"
                app:iconTint="#A07850" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCallHelper"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Call"
                android:textColor="#A07850"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_call"
                app:iconSize="16dp"
                app:iconTint="#A07850" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeleteHelper"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Remove"
                android:textColor="#C62828"
                android:textSize="12sp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconSize="16dp"
                app:iconTint="#C62828" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
