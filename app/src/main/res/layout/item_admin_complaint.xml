<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeColor="#E8D5BC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvAdminTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Complaint Title"
                android:textColor="#6B4C2A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btnDeleteComplaint"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#B00020"
                android:contentDescription="Delete" />

            <TextView
                android:id="@+id/tvAdminStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/badge_pending"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Pending"
                android:textColor="#8B5E30"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvAdminFlatNo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Flat No: ---"
            android:textColor="#A07850"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvAdminDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complaint description..."
            android:textColor="#5C3820"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <ImageView
            android:id="@+id/ivComplaintImage"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginBottom="12dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:background="#F5F5F5" />

        <LinearLayout
            android:id="@+id/layoutResolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FDF2E9"
            android:padding="8dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Resolution Details:"
                android:textColor="#6B4C2A"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvResolutionDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#6B4C2A"
                android:textSize="13sp"
                android:textStyle="italic" />

            <ImageView
                android:id="@+id/ivResolutionImage"
                android:layout_width="match_parent"
                android:layout_height="150dp"
                android:layout_marginTop="8dp"
                android:scaleType="centerCrop"
                android:background="#FFFFFF"
                android:visibility="gone" />
        </LinearLayout>

        <Button
            android:id="@+id/btnResolve"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="UPDATE STATUS"
            android:backgroundTint="#6B4C2A"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
