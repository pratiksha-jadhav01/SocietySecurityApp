<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/body_bg"
    tools:context=".AddDeliveryActivity">

    <!-- Header Wave Background -->
    <ImageView
        android:id="@+id/headerWave"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_header_wave"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Delivery Registry"
            app:titleTextColor="@color/dark_brown"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/dark_brown" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/appBar">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/card_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DELIVERY DETAILS"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="24dp"/>

                <!-- Photo Capture Section -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="24dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#F8F0E3"
                    app:strokeColor="#E8D5BC"
                    app:strokeWidth="1dp">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:id="@+id/imgDeliveryPhoto"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:src="@android:drawable/ic_menu_camera" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCapturePhoto"
                            style="@style/Widget.MaterialComponents.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:layout_marginBottom="12dp"
                            android:text="TAKE PHOTO"
                            android:textColor="@color/primary"
                            android:textStyle="bold"
                            app:backgroundTint="#80FFFFFF"
                            app:icon="@android:drawable/ic_menu_camera"
                            app:iconTint="@color/primary" />
                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Delivery Person Name"
                    app:startIconDrawable="@android:drawable/ic_menu_myplaces"
                    app:boxStrokeColor="@color/cream_field_stroke"
                    app:hintTextColor="@color/primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etDeliveryName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPersonName"
                        android:textColor="@color/dark_brown" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Company"
                    android:textColor="@color/dark_brown"
                    android:textStyle="bold"
                    android:textSize="13sp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupCompany"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:singleSelection="true">
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAmazon"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Amazon"
                        app:chipBackgroundColor="@color/light_cream"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_color"
                        android:textColor="@color/primary" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipSwiggy"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Swiggy"
                        app:chipBackgroundColor="@color/light_cream"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_color"
                        android:textColor="@color/primary" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipZomato"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Zomato"
                        app:chipBackgroundColor="@color/light_cream"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_color"
                        android:textColor="@color/primary" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipFlipkart"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Flipkart"
                        app:chipBackgroundColor="@color/light_cream"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_color"
                        android:textColor="@color/primary" />
                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipOtherCompany"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other"
                        app:chipBackgroundColor="@color/light_cream"
                        app:chipStrokeWidth="1dp"
                        app:chipStrokeColor="@color/border_color"
                        android:textColor="@color/primary" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilOtherCompany"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Specify Company"
                    android:visibility="gone"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:boxStrokeColor="@color/cream_field_stroke"
                    app:hintTextColor="@color/primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etOtherCompany"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/dark_brown" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Unit / Flat No"
                    app:startIconDrawable="@drawable/ic_home"
                    app:boxStrokeColor="@color/cream_field_stroke"
                    app:hintTextColor="@color/primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFlatNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textCapCharacters"
                        android:textColor="@color/dark_brown" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="Package Type (e.g. Food, Box)"
                    app:startIconDrawable="@android:drawable/ic_dialog_info"
                    app:boxStrokeColor="@color/cream_field_stroke"
                    app:hintTextColor="@color/primary">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPackageType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:textColor="@color/dark_brown" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmit"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginTop="24dp"
                    android:text="SUBMIT DELIVERY"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="12dp"
                    app:elevation="4dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:visibility="gone"
        android:indeterminateTint="@color/primary"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>