<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFF9F2"
    app:strokeColor="#E8D5BC"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvNoticeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@+id/ivDeleteNotice"
                android:layout_marginEnd="8dp"
                android:text="Notice Title"
                android:textColor="@color/admin_primary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/ivDeleteNotice"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_toStartOf="@+id/tvPostedBy"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="#D32F2F"
                android:visibility="gone"
                android:contentDescription="Delete Notice" />

            <TextView
                android:id="@+id/tvPostedBy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/badge_neutral"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="Admin"
                android:textColor="#8B6440"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvNoticeMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="This is the content of the society notice."
            android:textColor="#A07850"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E8D5BC" />

        <TextView
            android:id="@+id/tvNoticeDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="12 Oct 2023, 10:30 AM"
            android:textColor="#C8A882"
            android:textSize="11sp"
            android:textStyle="italic" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
