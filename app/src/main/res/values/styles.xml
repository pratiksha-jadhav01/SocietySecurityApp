<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Widget.Securio.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#FFF9F2</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#E8D5BC</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Securio.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#A07850</item>
        <item name="android:textColor">#FFF9F2</item>
        <item name="cornerRadius">12dp</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="TextAppearance.Securio.Header" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#6B4C2A</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Securio.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">#A07850</item>
    </style>

    <style name="Widget.Securio.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="backgroundTint">#FFFFFF</item>
        <item name="itemIconTint">@drawable/cream_nav_color</item>
        <item name="itemTextColor">@drawable/cream_nav_color</item>
    </style>

    <style name="CreamInputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/cream_field_stroke</item>
        <item name="boxBackgroundColor">#FFF9F2</item>
        <item name="hintTextColor">#A07850</item>
        <item name="android:textColorHint">#C8A882</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="CircleImage">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>